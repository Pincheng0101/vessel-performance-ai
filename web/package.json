{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.10.0",
  "engines": {
    "npm": ">=11.10.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
