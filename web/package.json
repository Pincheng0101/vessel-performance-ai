    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.36.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^29.1.1",
    "sass": "^1.77.8",
    "typescript-eslint": "^8.19.1",
