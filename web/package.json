    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.1.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.0.0",
    "@vueuse/nuxt": "^14.0.0",
    "asl-path-validator": "^0.17.0",
    "dayjs-nuxt": "^2.1.11",
    "echarts": "^6.1.0",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "libphonenumber-js": "^1.13.1",
    "marked-highlight": "^2.2.1",
    "marked-katex-extension": "^5.1.8",
    "nuxt": "^4.4.7",
