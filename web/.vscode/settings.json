{
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "editor.tabSize": 2,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.format.enable": true,
  "cSpell.words": [
    "agentcore",
    "brandmark",
    "chunker",
    "composables",
    "kklab",
    "langforge",
    "llm",
    "llms",
    "noopener",
    "noreferrer",
    "nuxt",
    "nuxtjs",
    "opensearch",
    "pinia",
    "rollbar",
    "stryle",
    "tseslint",
    "vuetify",
    "vueuse"
  ],
  "cSpell.ignorePaths": [
    ".nuxt/**",
    ".output/**",
    "dist/**",
    "node_modules/**",
    "public/**",
  ]
}
